{
	"image": "mcr.microsoft.com/devcontainers/universal:2",
	"features": {
		"ghcr.io/stu-bell/devcontainer-features/node:0": {},
		"ghcr.io/postfinance/devcontainer-features/node:1": {},
		"customizations": {
		"vscode": {
			"extensions": [
				"esbenp.prettier-vscode",
				"vscode-icons-team.vscode-icons",
